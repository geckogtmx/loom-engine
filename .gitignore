# --- Obsidian Vault (Knowledge) ---
# Ignore workspace state (cursor pos, open tabs) which changes constantly
knowledge/.obsidian/workspace.json
knowledge/.obsidian/workspace-mobile.json
knowledge/.obsidian/cache
knowledge/.obsidian/plugins/*/data.json

# Keep core config (themes, enabled plugins)
!knowledge/.obsidian/app.json
!knowledge/.obsidian/appearance.json
!knowledge/.obsidian/community-plugins.json
!knowledge/.obsidian/core-plugins.json
