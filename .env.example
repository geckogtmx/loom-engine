# LOOM Engine — Environment Variables Template
# Copy this file to .env and fill in your API keys

# --- LLM Provider API Keys ---
# OpenAI (for GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude 3.5 Sonnet, Claude 3 Opus)
ANTHROPIC_API_KEY=sk-ant-...

# Google (for Gemini 2.0 Flash, Gemini 1.5 Pro)
GOOGLE_API_KEY=...

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-...

# --- Ollama Configuration ---
# Local Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model (if not specified per-session)
# Available models: gemma3:4b, llama2, qwen2.5:7b, qwen2.5:14b, mistral, etc.
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
