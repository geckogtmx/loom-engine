# LOOM Engine — Environment Variables Template
# Copy this file to .env and fill in your configuration

# ============================================================================
# SECURITY NOTICE: API Key Storage (Phase 7.5 - 2026-01-15)
# ============================================================================
# API keys are now stored ENCRYPTED using Electron's safeStorage API.
# 
# On FIRST RUN:
# - LOOM will automatically migrate keys from .env to encrypted storage
# - Keys are encrypted using your OS keychain (macOS/Windows) or libsecret (Linux)
# - After migration, you can safely remove API keys from this .env file
#
# AFTER FIRST RUN:
# - Use the LOOM UI (Settings > API Keys) to manage keys securely
# - Keys entered via UI are automatically encrypted
# - .env is only used for development configuration
# ============================================================================

# --- LLM Provider API Keys (AUTO-MIGRATED ON FIRST RUN) ---
# These will be migrated to encrypted storage automatically.
# You DO NOT  need to keep them in .env after first run.

# OpenAI (for GPT-4o, GPT-4o-mini)
# OPENAI_API_KEY=sk-...

# Anthropic (for Claude 3.5 Sonnet, Claude 3 Opus)
# ANTHROPIC_API_KEY=sk-ant-...

# Google (for Gemini 2.0 Flash, Gemini 1.5 Pro)
# GOOGLE_API_KEY=...

# DeepSeek (OpenAI-compatible API)
# DEEPSEEK_API_KEY=sk-...

# --- Ollama Configuration (Not Encrypted - Local Only) ---
# Local Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model (if not specified per-session)
# Available models: gemma3:4b, llama2, qwen2.5:7b, qwen2.5:14b, mistral, etc.
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
